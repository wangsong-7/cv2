{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "cppbuild",
      "label": "g++ build",
      "command": "D:/mingw64/bin/g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}\\${fileBasenameNoExtension}.exe",
        "-I", "D:/opencv/build/include",
        "-L", "D:/opencv/build/x64/mingw/lib",
        "-lopencv_core490",
        "-lopencv_highgui490",
        "-lopencv_imgproc490",
        "-lopencv_imgcodecs490",
        "-lopencv_videoio490",
        "-lopencv_video490",
        "-lopencv_calib3d490",
        "-lopencv_features2d490",
        "-lopencv_objdetect490",
        "-lopencv_dnn490",
        "-lopencv_flann490",
        "-lopencv_photo490"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}