{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Build",
            "type": "shell",
            "command": "chcp 65001 && cmake --build D:/cv2/build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake .. -G \"MinGW Makefiles\" -DOpenCV_DIR=\"D:/opencv/build/x64/mingw\"",
            "options": {
                "cwd": "D:/cv2/build"
            }
        }
    ]
}